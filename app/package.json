{
  "name": "my-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:prod": "playwright test -c playwright.prod.config.ts",
    "data:audit": "node scripts/data/audit-consistency.mjs",
    "data:audit:json": "node scripts/data/audit-consistency.mjs --json",
    "data:collect:weekly": "node scripts/data/collect-weekly-sources.mjs",
    "data:source-tasks": "node scripts/data/build-source-tasks.mjs --write public/periodic-data/source-tasks.json --write public/weekly-data/source-tasks.json",
    "data:refresh:weekly": "node scripts/data/refresh-weekly-data.mjs",
    "data:refresh:semi-monthly": "node scripts/data/refresh-semi-monthly-data.mjs",
    "data:connector:amazon:dry-run": "node scripts/data/connectors/amazon-commerce-dry-run.mjs",
    "data:connector:amazon:mapping:validate": "node scripts/data/connectors/amazon-commerce-dry-run.mjs --json --no-write",
    "data:connector:amazon:mapping:template": "node scripts/data/connectors/amazon-commerce-dry-run.mjs --print-mapping-template",
    "data:connector:amazon:mapping:coverage": "node scripts/data/connectors/amazon-commerce-dry-run.mjs --coverage-report",
    "data:connector:amazon:mapping:archive": "node scripts/data/connectors/amazon-commerce-dry-run.mjs --archive-coverage-report",
    "data:connector:amazon:private:bootstrap": "node scripts/data/connectors/bootstrap-amazon-private-inputs.mjs",
    "data:connector:amazon:private:audit": "node scripts/data/connectors/amazon-commerce-private-input-audit.mjs",
    "data:connector:amazon:readiness": "node scripts/data/connectors/amazon-commerce-dry-run.mjs --readiness-gate",
    "data:connector:amazon:readiness:checklist": "node scripts/data/connectors/amazon-commerce-readiness-checklist.mjs",
    "data:connector:amazon:readiness:template": "node scripts/data/connectors/amazon-commerce-dry-run.mjs --print-readiness-template",
    "data:connector:voc-nlp:dry-run": "node scripts/data/connectors/voc-nlp-dry-run.mjs",
    "data:connector:voc-nlp:readiness": "node scripts/data/connectors/voc-nlp-dry-run.mjs --readiness-gate",
    "data:connector:voc-nlp:readiness:template": "node scripts/data/connectors/voc-nlp-dry-run.mjs --print-readiness-template",
    "data:connector:voc-nlp:sample:template": "node scripts/data/connectors/voc-nlp-dry-run.mjs --print-sample-manifest-template",
    "data:deploy:weekly": "bash scripts/data/weekly-refresh-and-deploy.sh",
    "data:publish:weekly:local": "bash scripts/data/weekly-refresh-local-static.sh",
    "data:deploy:semi-monthly": "bash scripts/data/semi-monthly-refresh-and-deploy.sh",
    "data:publish:semi-monthly:local": "bash scripts/data/semi-monthly-refresh-local-static.sh",
    "preview": "vite preview",
    "deploy:prod": "bash scripts/deploy-static.sh",
    "smoke:prod": "bash scripts/smoke-prod.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.70.0",
    "react-resizable-panels": "^4.2.2",
    "react-router": "^7.6.1",
    "react-router-dom": "^7.14.2",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "kimi-plugin-inspect-react": "^1.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.7"
  }
}
